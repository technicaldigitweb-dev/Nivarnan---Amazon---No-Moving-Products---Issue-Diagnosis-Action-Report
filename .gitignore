# See 00_PROJECT_CONTROL/PROTECTED_SOURCE_INVENTORY.md.
Sources/db_access_templates/
02_SOURCE/db_access_templates/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Large generated outputs / logs (not source-controlled)
09_OUTPUTS/logs/
09_OUTPUTS/data/
# Superseded/intermediate HTML build iterations (some >100MB) -- only the
# curated 09_OUTPUTS/html/production/ and .../test_versions/ subfolders
# are approved for Git; loose top-level iteration files are evidence-only.
09_OUTPUTS/html/*.html

# Runtime / temp / cache / secrets
secrets/
runtime/
logs/
*.log
.cache/
browser-profile/
playwright-report/
test-results/
tmp/
temp/
*.lock.runtime

# Raw source intake -- duplicated by curated copies inside the numbered
