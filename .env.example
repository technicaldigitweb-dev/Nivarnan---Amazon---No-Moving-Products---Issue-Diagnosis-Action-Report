# ANPIA direct PostgreSQL connection -- variable names only, no real values.
# Copy this file to .env locally and fill in real values there. .env is
# git-ignored and must never be committed or pasted into evidence/chat.
#
# Linux deployment (VM): restrict .env to the project operator account only,
#   chmod 600 .env
# Windows (this workstation): restrict NTFS access on the .env file to the
# project operator's own account (no equivalent chmod command applies).

ANPIA_DB_HOST=
ANPIA_DB_PORT=5432
ANPIA_DB_NAME=
ANPIA_DB_USER=
ANPIA_DB_PASSWORD=
ANPIA_DB_SSLMODE=require
